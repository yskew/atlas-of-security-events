# Copy to .env and fill in. With NO keys set, the pipeline still runs using the
# free public ctftime.org API (no web-search discovery / extraction).
# NEVER commit your real .env — it is gitignored.

# --- Database ---------------------------------------------------------------
# Local default (no setup): a SQLite file in the project dir.
# Prod (Neon/Postgres): postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# (the app normalizes postgresql:// -> postgresql+psycopg:// automatically)
DATABASE_URL=sqlite:///securityevents.db

# --- Gemini (free tier) -----------------------------------------------------
# Free key: https://aistudio.google.com/apikey
# One or more keys, comma-separated (each key's quota is per-project).
GEMINI_API_KEYS=
# Model fallback chain — each model has a SEPARATE free daily quota, tried in order.
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-flash-latest

# --- OpenRouter (free models) ----------------------------------------------
# Free models extend daily extraction capacity, tried AFTER Gemini's quota.
# Key: https://openrouter.ai/keys  (>=$10 lifetime credit raises the free-model
# daily cap from 50 to ~1000 requests/day; failed requests count toward it.)
OPENROUTER_API_KEY=
# Optional override; sensible free instruct models are the built-in default:
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,openai/gpt-oss-120b:free,z-ai/glm-4.5-air:free

# --- Pipeline knobs ---------------------------------------------------------
LOOKAHEAD_DAYS=365
HARD_PURGE_AFTER_DAYS=90

# Per city: dig through the ranked candidate pool, processing the top
# TARGET_FRESH_PER_CITY not-yet-done URLs (backfilling past dedup-skips).
MAX_SEARCH_RESULTS=20
MAX_URLS_PER_CITY=200
TARGET_FRESH_PER_CITY=15
MAX_SEARCH_QUERIES=60

# Run governor is TIME + a full city sweep (not a fixed count). 0 = unlimited.
MAX_EXTRACT_PER_RUN=0
# Wall-clock budget per run, in minutes. 0/unset = no cap (local: full sweep).
# GitHub Actions sets this to 300 (5h) so the job stops under the 6h kill limit.
RUN_MAX_MINUTES=0
# Throttle between extractions (protects provider rate limits).
EXTRACT_THROTTLE_SECONDS=6
# Re-verify an already-processed URL only after this many days.
REVERIFY_AFTER_DAYS=7
